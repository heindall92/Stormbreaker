<UserControl x:Class="Stormbreaker.Views.AiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Stormbreaker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <views:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Reusable Glass Card Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="17"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Page title -->
            <RowDefinition Height="*"/>    <!-- AI report interface -->
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ContentControl Content="{StaticResource IconBrain}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Txt[AiHeader]}" FontSize="19" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Txt[AiSub]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Main Report Interface (Glass Panel) -->
        <Border Grid.Row="1" Style="{StaticResource GlassPanel}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- AI Header (avatar, stats, status) -->
                    <RowDefinition Height="*"/>    <!-- Scrollable markdown output -->
                    <RowDefinition Height="Auto"/> <!-- Action triggers -->
                    <RowDefinition Height="Auto"/> <!-- Follow-up query row -->
                </Grid.RowDefinitions>

                <!-- AI Header -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Avatar -->
                        <ColumnDefinition Width="*"/>    <!-- Model Info -->
                        <ColumnDefinition Width="Auto"/> <!-- Status Badge -->
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="14" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8b5cf6" Offset="0.0"/>
                                <GradientStop Color="#f472b6" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentControl Content="{StaticResource IconBrain}" Style="{StaticResource DfirIcon}" Foreground="White" Width="22" Height="22"/>
                    </Border>

                    <!-- Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Txt[AiAnalystName]}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text=" · " FontSize="14" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding SelectedModel, FallbackValue=llama3.1:8b}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource AccentCyanBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Txt[AiSubtitleInfo]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Status Badge (Online vs Offline) -->
                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <!-- Online Status Badge -->
                        <Border CornerRadius="14" Padding="12,4" Background="#1F22c55e" BorderBrush="#5122c55e" BorderThickness="1"
                                Visibility="{Binding IsAiOnline, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <!-- Pulsing Ring -->
                                <Border Width="7" Height="7" CornerRadius="3.5" Background="{StaticResource AccentGreenBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Txt[AiStatusOnline]}" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Offline Status Badge -->
                        <Border CornerRadius="14" Padding="12,4" Background="#1Ff59e0b" BorderBrush="#51f59e0b" BorderThickness="1"
                                Visibility="{Binding IsAiOnline, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="7" Height="7" CornerRadius="3.5" Background="{StaticResource AccentOrangeBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Txt[AiStatusDemo]}" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Scrollable Output -->
                <Border Grid.Row="1" Background="#4D000000" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                    <Grid>
                        <!-- Loader / Thinking Panel -->
                        <StackPanel x:Name="LoaderPanel" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    Visibility="{Binding IsAiBusy, Converter={StaticResource BoolToVis}}">
                            <ContentControl Content="{StaticResource IconCpu}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentPurpleBrush}" Width="28" Height="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Txt[AiLoaderBuilding]}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding Txt[AiLoaderStreaming]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Content Textblock -->
                        <ScrollViewer x:Name="OutScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsAiBusy, Converter={StaticResource InverseBoolToVis}}">
                            <Grid>
                                <!-- Watermark when no analysis has run -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20" MaxWidth="600"
                                            Visibility="{Binding AiText, Converter={StaticResource InverseBoolToVis}, ConverterParameter=empty}">
                                    <TextBlock Text="{Binding Txt[AiWatermarkHeader]}" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding Txt[AiWatermarkDesc]}"
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" TextWrapping="Wrap" LineHeight="18"/>
                                    <TextBlock Text="{Binding Txt[AiWatermarkWarning]}"
                                               FontSize="11" Foreground="{StaticResource AccentOrangeBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0" LineHeight="16"/>
                                </StackPanel>

                                <!-- Flow markdown content -->
                                <TextBlock FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20" TextWrapping="Wrap"
                                           views:MarkdownTextHelper.Markdown="{Binding AiText}"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Action Triggers -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
                    <Button Style="{StaticResource BtnPrimary}" Content="{Binding Txt[AiBtnAnalyze]}" Command="{Binding RunAiAnalysisCommand}" CommandParameter="" IsEnabled="{Binding IsAiBusy, Converter={StaticResource InverseBoolToVis}}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource BtnGlass}" Content="{Binding Txt[AiBtnDeepDive]}" Command="{Binding RunAiAnalysisCommand}" CommandParameter="powershell deep dive on event 4104" IsEnabled="{Binding IsAiBusy, Converter={StaticResource InverseBoolToVis}}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource BtnGlass}" Content="{Binding Txt[AiBtnCorrelate]}" Command="{Binding NavigateCommand}" CommandParameter="correlation" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource BtnGlass}" Content="{Binding Txt[AiBtnExport]}" Command="{Binding NavigateCommand}" CommandParameter="reports"/>
                </StackPanel>

                <!-- Follow-up query row -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" Background="#40000000" CornerRadius="8" Padding="12,6" Margin="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ContentControl Content="{StaticResource IconSearch}" Style="{StaticResource DfirIcon}" Width="15" Height="15" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="QuestionBox" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13" VerticalAlignment="Center" CaretBrush="{StaticResource AccentCyanBrush}"
                                     Tag="{Binding Txt[AiAskPlaceholder]}"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1" Style="{StaticResource BtnGlass}" Content="{Binding Txt[AiBtnAsk]}" 
                            Command="{Binding RunAiAnalysisCommand}" 
                            CommandParameter="{Binding ElementName=QuestionBox, Path=Text}"
                            IsEnabled="{Binding IsAiBusy, Converter={StaticResource InverseBoolToVis}}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
