<UserControl x:Class="Stormbreaker.Views.EventsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Stormbreaker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <views:SeverityToBrushConverter x:Key="SevToBrush"/>
        <views:SeverityToBackplateConverter x:Key="SevToBackplate"/>
        <views:BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Reusable Glass Card Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="17"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Reusable Chip Filter Button Style -->
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Background" Value="#0DFFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1AFFFFFF"/>
                    <Setter Property="BorderBrush" Value="{StaticResource GlassBorderLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom flat toggle style for the table rows -->
        <Style x:Key="RowButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="4,6" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0C00d4ff"/> <!-- 5% cyan overlay on hover -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Table Header Button Style -->
        <Style x:Key="TableHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Page title -->
            <RowDefinition Height="*"/>    <!-- Logs list container -->
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ContentControl Content="{StaticResource IconFileText}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Txt[Events]}" FontSize="19" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Txt[EventsSub]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            
            <Border Background="#1F00d4ff" BorderBrush="#5100d4ff" BorderThickness="1" CornerRadius="12" Padding="12,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding FilteredEvents.Count, FallbackValue=0}" Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold"/>
                    <TextBlock Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding Events.Count, FallbackValue=0}" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding Txt[EventsCountSuffix]}" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Table Container -->
        <Border Grid.Row="1" Style="{StaticResource GlassPanel}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Toolbar (Search + Chips) -->
                    <RowDefinition Height="Auto"/> <!-- Table Headers -->
                    <RowDefinition Height="*"/>    <!-- Scrollable content rows -->
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Box -->
                    <Border Grid.Column="0" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" Background="#40000000" CornerRadius="8" Padding="12,6" HorizontalAlignment="Stretch" Margin="0,0,14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ContentControl Content="{StaticResource IconSearch}" Style="{StaticResource DfirIcon}" Width="15" Height="15" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="13" VerticalAlignment="Center" CaretBrush="{StaticResource AccentCyanBrush}"
                                     Text="{Binding EventSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     d:Text="svchost"/>
                        </Grid>
                    </Border>

                    <!-- Severity Filter Chips -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- All -->
                        <Button Command="{Binding SetSeverityFilterCommand}" CommandParameter="all">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverityFilter}" Value="all">
                                            <Setter Property="Background" Value="#2600d4ff"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="{Binding Txt[SeverityAll]}"/>
                        </Button>
                        
                        <!-- Critical -->
                        <Button Command="{Binding SetSeverityFilterCommand}" CommandParameter="critical">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverityFilter}" Value="critical">
                                            <Setter Property="Background" Value="#26ef4444"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Txt[SeverityCritical]}"/>
                                <Border Background="#26ef4444" CornerRadius="4" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="3" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}"/>
                                </Border>
                            </StackPanel>
                        </Button>
                        
                        <!-- Warning -->
                        <Button Command="{Binding SetSeverityFilterCommand}" CommandParameter="warning">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverityFilter}" Value="warning">
                                            <Setter Property="Background" Value="#26f59e0b"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Txt[SeverityWarning]}"/>
                                <Border Background="#26f59e0b" CornerRadius="4" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="4" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentOrangeBrush}"/>
                                </Border>
                            </StackPanel>
                        </Button>
                        
                        <!-- Info -->
                        <Button Command="{Binding SetSeverityFilterCommand}" CommandParameter="info">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverityFilter}" Value="info">
                                            <Setter Property="Background" Value="#263b82f6"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Txt[SeverityInfo]}"/>
                                <Border Background="#263b82f6" CornerRadius="4" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="6" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <!-- Success -->
                        <Button Command="{Binding SetSeverityFilterCommand}" CommandParameter="success">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSeverityFilter}" Value="success">
                                            <Setter Property="Background" Value="#2622c55e"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Txt[SeverityNotable]}"/>
                                <Border Background="#2622c55e" CornerRadius="4" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="1" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}"/>
                                </Border>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Grid Table Headers -->
                <Border Grid.Row="1" Background="#D6101628" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1" Padding="8,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>  <!-- Time -->
                            <ColumnDefinition Width="60"/>  <!-- EID -->
                            <ColumnDefinition Width="130"/> <!-- Channel -->
                            <ColumnDefinition Width="85"/>  <!-- Level -->
                            <ColumnDefinition Width="160"/> <!-- Source -->
                            <ColumnDefinition Width="110"/> <!-- User -->
                            <ColumnDefinition Width="*"/>   <!-- Message -->
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource TableHeaderButton}" Content="{Binding Txt[ColTime]}" Command="{Binding SortEventsCommand}" CommandParameter="t"/>
                        <Button Grid.Column="1" Style="{StaticResource TableHeaderButton}" Content="{Binding Txt[ColEid]}" Command="{Binding SortEventsCommand}" CommandParameter="id"/>
                        <Button Grid.Column="2" Style="{StaticResource TableHeaderButton}" Content="{Binding Txt[ColChannel]}" Command="{Binding SortEventsCommand}" CommandParameter="ch"/>
                        <Button Grid.Column="3" Style="{StaticResource TableHeaderButton}" Content="{Binding Txt[ColLevel]}" Command="{Binding SortEventsCommand}" CommandParameter="lvl"/>
                        <Button Grid.Column="4" Style="{StaticResource TableHeaderButton}" Content="{Binding Txt[ColSource]}" Command="{Binding SortEventsCommand}" CommandParameter="src"/>
                        <Button Grid.Column="5" Style="{StaticResource TableHeaderButton}" Content="{Binding Txt[ColUser]}" Command="{Binding SortEventsCommand}" CommandParameter="user"/>
                        <TextBlock Grid.Column="6" Text="{Binding Txt[ColMsgMitre]}" FontWeight="Bold" FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Expandable Data Rows -->
                <ListBox Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0" Focusable="False"
                         HorizontalContentAlignment="Stretch" VerticalContentAlignment="Top"
                         ItemsSource="{Binding FilteredEvents, Mode=OneWay}">
                    
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Row outer border -->
                            <Border x:Name="RowBorder" BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <!-- Main click triggers expand -->
                                    <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}" Style="{StaticResource RowButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>  <!-- Time -->
                                                <ColumnDefinition Width="60"/>  <!-- EID -->
                                                <ColumnDefinition Width="130"/> <!-- Channel -->
                                                <ColumnDefinition Width="85"/>  <!-- Level -->
                                                <ColumnDefinition Width="160"/> <!-- Source -->
                                                <ColumnDefinition Width="110"/> <!-- User -->
                                                <ColumnDefinition Width="*"/>   <!-- Message -->
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding T}" Foreground="White" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Id}" Foreground="White" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Ch}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                                            
                                            <!-- Level Badge -->
                                            <Border Grid.Column="3" CornerRadius="5" Padding="7,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="{Binding Lvl, Converter={StaticResource SevToBackplate}}">
                                                <TextBlock Text="{Binding Lvl}" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center"
                                                           Foreground="{Binding Lvl, Converter={StaticResource SevToBrush}}"/>
                                            </Border>

                                            <TextBlock Grid.Column="4" Text="{Binding Src}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                            <TextBlock Grid.Column="5" Text="{Binding User}" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource FontMono}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                            
                                            <!-- Message + MITRE Badges (Responsive DockPanel) -->
                                             <DockPanel Grid.Column="6" LastChildFill="True">
                                                 <!-- Mitre badges list on the right -->
                                                 <ItemsControl DockPanel.Dock="Right" ItemsSource="{Binding Mitre}" Margin="8,0,0,0" Focusable="False" VerticalAlignment="Center">
                                                     <ItemsControl.ItemsPanel>
                                                         <ItemsPanelTemplate>
                                                             <StackPanel Orientation="Horizontal"/>
                                                         </ItemsPanelTemplate>
                                                     </ItemsControl.ItemsPanel>
                                                     <ItemsControl.ItemTemplate>
                                                         <DataTemplate>
                                                             <Border Background="#1F8b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="5" Padding="6,1" Margin="2,0">
                                                                 <TextBlock Text="{Binding}" Foreground="{StaticResource AccentPurpleBrush}" FontFamily="{StaticResource FontMono}" FontSize="9.5" FontWeight="SemiBold"/>
                                                             </Border>
                                                         </DataTemplate>
                                                     </ItemsControl.ItemTemplate>
                                                 </ItemsControl>

                                                 <!-- Message text filling left and auto-trimming -->
                                                 <TextBlock Text="{Binding Msg}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                             </DockPanel>
                                        </Grid>
                                    </ToggleButton>

                                    <!-- Expanded details panel -->
                                    <Border Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" 
                                            Background="#4D000000" Padding="18,14" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Timestamp -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Txt[DetailTimestamp]}" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Ts}" Foreground="White" FontFamily="{StaticResource FontMono}" FontSize="12" Margin="0,0,0,6"/>

                                            <!-- Process ID -->
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Txt[DetailPid]}" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Pid}" Foreground="White" FontFamily="{StaticResource FontMono}" FontSize="12" Margin="0,0,0,6"/>

                                            <!-- MITRE -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Txt[DetailMitre]}" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                            <!-- Join mitre array with comma -->
                                            <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Mitre}" Margin="0,0,0,6" Focusable="False">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="White" FontFamily="{StaticResource FontMono}" FontSize="12" Margin="0,0,10,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Dynamic Key Value Detail properties -->
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Txt[DetailHeader]}" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="12"/>
                                            <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Detail}" Focusable="False">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,24,8">
                                                            <TextBlock Text="{Binding Key}" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" FontSize="11.5" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Value}" Foreground="White" FontFamily="{StaticResource FontMono}" FontSize="12" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                            
                            <!-- Trigger for critical row background red outline -->
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Lvl}" Value="critical">
                                    <Setter TargetName="RowBorder" Property="Background" Value="#0Fef4444"/> <!-- 6% transparent red backplate -->
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
