<UserControl x:Class="Stormbreaker.Views.CorrelationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Stormbreaker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <views:SeverityToBrushConverter x:Key="SevToBrush"/>
        <views:SeverityToBackplateConverter x:Key="SevToBackplate"/>
        <views:IconNameToResourceConverter x:Key="IconToRes"/>

        <!-- Reusable Glass Card Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="17"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Glass Card Style (for Chain Nodes) -->
        <Style x:Key="NodeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0AFFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource GlassBorderLightBrush}"/>
                    <Setter Property="Background" Value="#10FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
        <Grid Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Page title -->
                <RowDefinition Height="Auto"/> <!-- Explanation block -->
                <RowDefinition Height="Auto"/> <!-- Reconstructed Attack Chain -->
                <RowDefinition Height="Auto"/> <!-- MITRE Coverage -->
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Content="{StaticResource IconGitMerge}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Correlation Engine" FontSize="19" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Cross-referencing artifacts by PID, path and time-window into a single attack narrative" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                
                <Border Background="#1F8b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="12" Padding="12,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding AttackCatalog.Count, FallbackValue=14}" Foreground="{StaticResource AccentPurpleBrush}" FontWeight="Bold"/>
                        <TextBlock Text=" ATT&amp;CK techniques" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Explanation Block -->
            <Border Grid.Row="1" Style="{StaticResource GlassPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Background="#1F8b5cf6" Margin="0,0,14,0" VerticalAlignment="Top">
                        <ContentControl Content="{StaticResource IconActivity}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentPurpleBrush}" Width="18" Height="18"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" LineHeight="20">
                            Stormbreaker linked <Run Text="{Binding Events.Count, Mode=OneWay, FallbackValue=14}" FontWeight="Bold" Foreground="White"/> events across 
                            <Run Text="4 artifact sources" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}"/> (Event Logs · MFT · Registry · USN) using the pivot process 
                            <Run Text="PID 4821" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Foreground="White"/>, the shared path 
                            <Run Text="%APPDATA%\svchost.exe" FontFamily="{StaticResource FontMono}" Foreground="White"/> and 90-second correlation windows. The result is the reconstructed kill-chain below.
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Reconstructed Attack Chain -->
            <Border Grid.Row="2" Style="{StaticResource GlassPanel}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{StaticResource IconTarget}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentRedBrush}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reconstructed Attack Chain" FontSize="13.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Background="#26ef4444" BorderBrush="#51ef4444" BorderThickness="1" CornerRadius="10" Padding="10,3" HorizontalAlignment="Right">
                            <TextBlock Text="7 PHASES IDENTIFIED" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}"/>
                        </Border>
                    </Grid>

                    <!-- Timeline layout with vertical rail and cards -->
                    <Grid>
                        <!-- Continuous Vertical line in the background -->
                        <Rectangle Width="2" Fill="{StaticResource GlassBorderBrush}" HorizontalAlignment="Left" Margin="35,16,0,26" VerticalAlignment="Stretch"/>

                        <!-- Nodes List -->
                        <ItemsControl ItemsSource="{Binding Chain, Mode=OneWay}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>  <!-- Vertical Rail -->
                                            <ColumnDefinition Width="*"/>   <!-- Content Card -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Circular Icon Marker -->
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" VerticalAlignment="Top" Margin="0,6,0,0"
                                                Background="{StaticResource BgDeepBrush}"
                                                BorderBrush="{Binding Color, Converter={StaticResource SevToBrush}}"
                                                BorderThickness="1.5">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="White" Opacity="0.15"/>
                                            </Border.Effect>
                                            <ContentControl Content="{Binding Ic, Converter={StaticResource IconToRes}}" Style="{StaticResource DfirIcon}" 
                                                            Foreground="{Binding Color, Converter={StaticResource SevToBrush}}" Width="16" Height="16"/>
                                        </Border>

                                        <!-- Glass Node Detail Card -->
                                        <Border Grid.Column="1" Style="{StaticResource NodeCardStyle}">
                                            <StackPanel>
                                                <!-- Phase + Timestamp -->
                                                <TextBlock FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                                           Foreground="{Binding Color, Converter={StaticResource SevToBrush}}">
                                                    <Run Text="{Binding Phase, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding T}"/>
                                                </TextBlock>
                                                
                                                <!-- Title -->
                                                <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                                
                                                <!-- Meta pivot description -->
                                                <TextBlock Text="{Binding Meta}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap" FontFamily="{StaticResource FontMono}"/>

                                                <!-- Tag Wrap Panel (MITRE techniques + evidence sources) -->
                                                <WrapPanel>
                                                    <!-- MITRE ID Badges -->
                                                    <ItemsControl ItemsSource="{Binding Mitre}" Focusable="False">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#1F8b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="5" Padding="7,2" Margin="0,0,6,4" ToolTip="MITRE ATT&amp;CK Technique">
                                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource AccentPurpleBrush}" FontFamily="{StaticResource FontMono}" FontSize="9.5" FontWeight="Bold"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Evidence Sources Badges -->
                                                    <ItemsControl ItemsSource="{Binding Src}" Focusable="False">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#26000000" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="7,2" Margin="0,0,6,4" ToolTip="Evidence Source Citation">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <ContentControl Content="{StaticResource IconDatabase}" Style="{StaticResource DfirIcon}" Width="10" Height="10" Margin="0,0,5,0" Foreground="{StaticResource TextMutedBrush}"/>
                                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource FontMono}" FontSize="9.5"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- MITRE ATT&CK Coverage -->
            <Border Grid.Row="3" Style="{StaticResource GlassPanel}" Margin="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="MITRE ATT&amp;CK Coverage" FontSize="13.5" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>
                    
                    <!-- Tags Cloud -->
                    <ItemsControl ItemsSource="{Binding AttackCatalog}" Focusable="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1F8b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="5" Padding="9,4" Margin="3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Key}" Foreground="{StaticResource AccentPurpleBrush}" FontFamily="{StaticResource FontMono}" FontSize="11" FontWeight="Bold" Margin="0,0,6,0"/>
                                        <TextBlock Text="·" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Value}" Foreground="{StaticResource AccentPurpleBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
