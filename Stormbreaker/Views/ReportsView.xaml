<UserControl x:Class="Stormbreaker.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Stormbreaker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <views:SeverityToBrushConverter x:Key="SevToBrush"/>
        <views:SeverityToBackplateConverter x:Key="SevToBackplate"/>
        
        <!-- Reusable Glass Card Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="17"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Small Flat Icon Button Style -->
        <Style x:Key="FlatIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" CornerRadius="4" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
        <Grid Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Page title -->
                <RowDefinition Height="Auto"/> <!-- Executive report card -->
                <RowDefinition Height="*"/>    <!-- 2-Column Split (IOCs & ATT&CK) -->
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Content="{StaticResource IconFileText}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Txt[ReportsHeader]}" FontSize="19" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Txt[ReportsSub]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Header Actions (Export triggers) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnGlass}" Command="{Binding ExportMarkdownCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{StaticResource IconFileText}" Style="{StaticResource DfirIcon}" Margin="0,0,8,0"/>
                            <TextBlock Text="Markdown" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BtnGlass}" Command="{Binding ExportJsonCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{StaticResource IconDownload}" Style="{StaticResource DfirIcon}" Margin="0,0,8,0"/>
                            <TextBlock Text="IOCs (JSON)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Executive Report Card -->
            <Border Grid.Row="1" Style="{StaticResource GlassPanel}">
                <DockPanel>
                    <!-- Card Header -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{StaticResource IconFileText}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Txt[ReportExecutiveCaseHeader]}" FontSize="13.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Background="#1F22c55e" BorderBrush="#5122c55e" BorderThickness="1" CornerRadius="10" Padding="10,3" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Txt[ReportReadyHandoff]}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}"/>
                        </Border>
                    </Grid>

                    <!-- Report Content -->
                    <StackPanel>
                        <Border Background="#26000000" CornerRadius="8" Padding="14" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding Txt[ReportSummary]}" FontSize="12.5" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Txt[ExecSummaryText]}"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" LineHeight="18" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#26000000" CornerRadius="8" Padding="14" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding Txt[ReportImpact]}" FontSize="12.5" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Txt[ReportImpactText]}"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" LineHeight="18" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Recommended Actions checklist -->
                        <Border Background="#26000000" CornerRadius="8" Padding="14" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Txt[PlaybookHeader]}" FontSize="12.5" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="1." Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Txt[ReportAction1]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="2." Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Txt[ReportAction2]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="3." Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Txt[ReportAction3]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="4." Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Txt[ReportAction4]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="5." Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Txt[ReportAction5]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 2-Column Split: IOCs (left) vs ATT&CK (right) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE: Indicators of Compromise -->
                <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Margin="0,0,7,0">
                    <DockPanel>
                        <!-- Header -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <ContentControl Content="{StaticResource IconTarget}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Txt[IocHeader]}" FontSize="13.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Style="{StaticResource BtnGlass}" HorizontalAlignment="Right" Command="{Binding CopyIocsCommand}" Padding="8,4">
                                    <StackPanel Orientation="Horizontal">
                                        <ContentControl Content="{StaticResource IconCopy}" Style="{StaticResource DfirIcon}" Margin="0,0,6,0" Width="12" Height="12"/>
                                        <TextBlock Text="{Binding Txt[BtnCopyAll]}" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- IOCs list -->
                        <ItemsControl ItemsSource="{Binding Iocs, Mode=OneWay}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#06FFFFFF" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Type pill -->
                                                <ColumnDefinition Width="*"/>    <!-- Value + details -->
                                                <ColumnDefinition Width="Auto"/> <!-- Confidence Badge -->
                                                <ColumnDefinition Width="Auto"/> <!-- Copy single button -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Type Pill -->
                                            <Border Grid.Column="0" Background="#1FFFFFFF" CornerRadius="4" Padding="6,2" VerticalAlignment="Top" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Type}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                            </Border>

                                            <!-- Value + description -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Val}" FontSize="12.5" FontWeight="Bold" Foreground="White" FontFamily="{StaticResource FontMono}"/>
                                                <TextBlock Text="{Binding Ctx}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Confidence Badge -->
                                            <Border Grid.Column="2" CornerRadius="5" Padding="6,2" Margin="10,0" VerticalAlignment="Top"
                                                    Background="{Binding Conf, Converter={StaticResource SevToBackplate}}">
                                                <TextBlock Text="{Binding Conf}" FontSize="9.5" FontWeight="Bold"
                                                           Foreground="{Binding Conf, Converter={StaticResource SevToBrush}}"/>
                                            </Border>

                                            <!-- Copy Single Indicator Button -->
                                            <Button Grid.Column="3" Style="{StaticResource FlatIconButton}" VerticalAlignment="Top"
                                                    Command="{Binding DataContext.CopySingleIocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Val}">
                                                <ContentControl Content="{StaticResource IconCopy}" Style="{StaticResource DfirIcon}" Width="12" Height="12" Foreground="{StaticResource TextMutedBrush}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- RIGHT SIDE: Mapped ATT&CK Techniques -->
                <Border Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="7,0,0,0">
                    <DockPanel>
                        <!-- Header -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <ContentControl Content="{StaticResource IconShield}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentPurpleBrush}" Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Txt[MitreObservedHeader]}" FontSize="13.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="#268b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AttackCatalog.Count, FallbackValue=14}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}"/>
                            </Border>
                        </Grid>

                        <!-- Techniques list -->
                        <ItemsControl ItemsSource="{Binding AttackCatalog, Mode=OneWay}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#06FFFFFF" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- ID Badge -->
                                                <ColumnDefinition Width="*"/>    <!-- Name -->
                                            </Grid.ColumnDefinitions>

                                            <!-- ID Badge -->
                                            <Border Grid.Column="0" Background="#1F8b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Key}" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}" FontFamily="{StaticResource FontMono}"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12.5" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
