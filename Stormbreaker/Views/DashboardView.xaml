<UserControl x:Class="Stormbreaker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Stormbreaker.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    
    <UserControl.Resources>
        <views:SeverityToBrushConverter x:Key="SevToBrush"/>
        
        <LinearGradientBrush x:Key="BarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00d4ff" Offset="0.0"/>
            <GradientStop Color="#3b82f6" Offset="1.0"/>
        </LinearGradientBrush>
        
        <!-- Style for Glass Panels -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="17"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
        <Grid Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Page title -->
                <RowDefinition Height="Auto"/> <!-- Stat cards grid -->
                <RowDefinition Height="Auto"/> <!-- Main content grid (Timeline + charts) -->
                <RowDefinition Height="Auto"/> <!-- AI Summary -->
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Content="{StaticResource IconLayoutGrid}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Case Overview" FontSize="19" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0">
                        <Run Text="{Binding Case.Id, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Run Text=" · host "/>
                        <Run Text="{Binding Case.Host, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding Case.Os, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Stats Grid (4 Columns) -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                <!-- Events Correlated -->
                <Border Style="{StaticResource GlassPanel}" Margin="0,0,7,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Events Correlated" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                            <Border Width="30" Height="30" CornerRadius="8" Background="#1F00d4ff" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <ContentControl Content="{StaticResource IconActivity}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="16" Height="16"/>
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1" Text="47,832" FontSize="25" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Text="+12% vs last scan" FontSize="11" FontWeight="Medium" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <!-- MFT Records -->
                <Border Style="{StaticResource GlassPanel}" Margin="7,0,7,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="MFT Records" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                            <Border Width="30" Height="30" CornerRadius="8" Background="#1F8b5cf6" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <ContentControl Content="{StaticResource IconHardDrive}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentPurpleBrush}" Width="16" Height="16"/>
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1" Text="1.24M" FontSize="25" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Text="+8% new entries" FontSize="11" FontWeight="Medium" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <!-- Critical Threats -->
                <Border Style="{StaticResource GlassPanel}" Margin="7,0,7,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Critical Threats" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                            <Border Width="30" Height="30" CornerRadius="8" Background="#1Fef4444" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <ContentControl Content="{StaticResource IconShield}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentRedBrush}" Width="16" Height="16"/>
                            </Border>
                        </Grid>
                        <!-- Bind to Events with critical level count -->
                        <TextBlock Grid.Row="1" Text="3" FontSize="25" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Text="+3 need triage" FontSize="11" FontWeight="Medium" Foreground="{StaticResource AccentRedBrush}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <!-- Time to Insight -->
                <Border Style="{StaticResource GlassPanel}" Margin="7,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Time to Insight" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                            <Border Width="30" Height="30" CornerRadius="8" Background="#1Ff59e0b" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <ContentControl Content="{StaticResource IconClock}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentOrangeBrush}" Width="16" Height="16"/>
                            </Border>
                        </Grid>
                        <TextBlock Grid.Row="1" Text="4m 32s" FontSize="25" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Text="−87% vs manual" FontSize="11" FontWeight="Medium" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Main Content Grid: Timeline on left, Charts on right -->
            <Grid Grid.Row="2" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE: Timeline -->
                <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Margin="0,0,10,14">
                    <DockPanel>
                        <!-- Panel Header -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Border.Effect>
                                        <BlurEffect Radius="4"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="Forensic Timeline Alerts" FontSize="13.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="#2600d4ff" BorderBrush="#5100d4ff" BorderThickness="1" CornerRadius="10" Padding="10,3" HorizontalAlignment="Right">
                                <TextBlock Text="LIVE ALERT CHANNEL" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}"/>
                            </Border>
                        </Grid>

                        <!-- Panel Bottom Button -->
                        <Button DockPanel.Dock="Bottom" Style="{StaticResource BtnGlass}" HorizontalAlignment="Left" Margin="0,6,0,0"
                                Command="{Binding NavigateCommand}" CommandParameter="timeline">
                            <StackPanel Orientation="Horizontal">
                                <ContentControl Content="{StaticResource IconClock}" Style="{StaticResource DfirIcon}" Margin="0,0,8,0"/>
                                <TextBlock Text="View full chronology" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Chronology list of top 5 events -->
                        <ItemsControl ItemsSource="{Binding Events, Mode=OneWay}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#06FFFFFF" BorderBrush="Transparent" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Dot -->
                                                <ColumnDefinition Width="*"/>    <!-- Text content -->
                                                <ColumnDefinition Width="Auto"/> <!-- Time -->
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Severity Dot -->
                                            <Border Grid.Column="0" Width="9" Height="9" CornerRadius="4.5" Margin="0,4,12,0" VerticalAlignment="Top"
                                                    Background="{Binding Lvl, Converter={StaticResource SevToBrush}}">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="White" Opacity="0.3"/>
                                                </Border.Effect>
                                            </Border>

                                            <!-- Msg details -->
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Src}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                    <TextBlock Text=" · EID " FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <TextBlock Text="{Binding Id}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Msg}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="3" Text="{Binding T}" FontSize="10.5" FontFamily="{StaticResource FontMono}" Foreground="{StaticResource TextMutedBrush}" Margin="10,2,0,0" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- RIGHT SIDE: Severity Breakdown & Artifact Activity -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    
                    <!-- Severity breakdown panel -->
                    <Border Style="{StaticResource GlassPanel}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Severity Breakdown" FontSize="13.5" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,14"/>
                            
                            <!-- Clean list view of severity details -->
                            <StackPanel>
                                <Grid Margin="0,0,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="10" Height="10" CornerRadius="3" Background="{StaticResource AccentRedBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="Critical Threats" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="3" FontSize="12" FontWeight="Bold" Foreground="White" FontFamily="{StaticResource FontMono}"/>
                                </Grid>
                                <Grid Margin="0,0,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="10" Height="10" CornerRadius="3" Background="{StaticResource AccentOrangeBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="Warnings / LOLBins" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="4" FontSize="12" FontWeight="Bold" Foreground="White" FontFamily="{StaticResource FontMono}"/>
                                </Grid>
                                <Grid Margin="0,0,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="10" Height="10" CornerRadius="3" Background="{StaticResource AccentBlueBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="Informational logs" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="6" FontSize="12" FontWeight="Bold" Foreground="White" FontFamily="{StaticResource FontMono}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="10" Height="10" CornerRadius="3" Background="{StaticResource AccentGreenBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="Notable Network logons" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="1" FontSize="12" FontWeight="Bold" Foreground="White" FontFamily="{StaticResource FontMono}"/>
                                </Grid>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Artifact Activity Chart panel -->
                    <Border Style="{StaticResource GlassPanel}" Margin="0">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                                <TextBlock Text="Artifact Activity (24h)" FontSize="13.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Background="#263b82f6" BorderBrush="#513b82f6" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,4,0">
                                        <TextBlock Text=".evtx" FontSize="9" Foreground="{StaticResource AccentBlueBrush}" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#268b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="MFT" FontSize="9" Foreground="{StaticResource AccentPurpleBrush}" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Simple visual vector bar representation -->
                            <StackPanel>
                                <Grid Height="120" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 12 visual bars representing hourly activity -->
                                    <Border Grid.Column="0" VerticalAlignment="Bottom" Height="30" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="1" VerticalAlignment="Bottom" Height="50" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="2" VerticalAlignment="Bottom" Height="40" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="3" VerticalAlignment="Bottom" Height="80" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="4" VerticalAlignment="Bottom" Height="70" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="5" VerticalAlignment="Bottom" Height="100" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="6" VerticalAlignment="Bottom" Height="75" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="7" VerticalAlignment="Bottom" Height="45" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="8" VerticalAlignment="Bottom" Height="60" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="9" VerticalAlignment="Bottom" Height="90" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="10" VerticalAlignment="Bottom" Height="55" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                    <Border Grid.Column="11" VerticalAlignment="Bottom" Height="110" Margin="4,0" CornerRadius="4,4,0,0" Background="{StaticResource BarBrush}" Opacity="0.7"/>
                                </Grid>
                                
                                <Grid Margin="0,4,0,0">
                                    <TextBlock Text="00:00" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="12:00" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="23:59" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Bottom Panel: AI Summary -->
            <Border Grid.Row="3" Style="{StaticResource GlassPanel}" Margin="0,14,0,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{StaticResource IconBrain}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentPurpleBrush}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="AI Executive Summary" FontSize="13.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Background="#268b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="10" Padding="10,3" HorizontalAlignment="Right">
                            <TextBlock Text="OLLAMA LOCAL LLM" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}"/>
                        </Border>
                    </Grid>
                    
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left" Margin="0,14,0,0"
                            Command="{Binding NavigateCommand}" CommandParameter="ai">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{StaticResource IconBrain}" Style="{StaticResource DfirIcon}" Foreground="White" Margin="0,0,8,0"/>
                            <TextBlock Text="Open full analysis in AI Analyst" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Background="#3B000000" CornerRadius="8" Padding="14" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                        <TextBlock Text="High-confidence intrusion on FIN-WKS-07 beginning 14:02 UTC. Living-off-the-land chain: USB delivery → obfuscated PowerShell → C2 to 185.220.101.47 → Run-key + service persistence → timestomp &amp; log clearing → destruction of 847 files. Shadow copies deleted. Lateral logon to a peer host observed. Recommend immediate isolation and memory capture before shutdown."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" LineHeight="20" TextWrapping="Wrap"/>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
