<Window x:Class="Stormbreaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Stormbreaker"
        xmlns:views="clr-namespace:Stormbreaker.Views"
        xmlns:viewmodels="clr-namespace:Stormbreaker.ViewModels"
        mc:Ignorable="d"
        Title="Stormbreaker — DFIR Console" 
        Height="780" Width="1240"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <views:ActiveViewToBrushConverter x:Key="ActiveViewToBrush"/>
        <views:ActiveViewToForegroundConverter x:Key="ActiveViewToForeground"/>
        <views:ActiveViewToBorderBrushConverter x:Key="ActiveViewToBorderBrush"/>
        <views:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        
        <!-- Collapsible Sidebar Style with smooth width animation -->
        <Style x:Key="SidebarBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Background" Value="#BF0A0E1A"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="0,16"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="220"
                                                 Duration="0:0:0.25"
                                                 DecelerationRatio="0.85"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="70"
                                                 Duration="0:0:0.25"
                                                 DecelerationRatio="0.85"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for Nav Sidebar Button -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="11,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource GlassBorderLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ============================================================
             DYNAMIC RADIAL GRADIENT MESH BACKGROUND
             ============================================================ -->
        <Grid.Background>
            <VisualBrush Stretch="None">
                <VisualBrush.Visual>
                    <Grid Width="1920" Height="1080" Background="{StaticResource BgDeepBrush}">
                        <!-- Top-Left Cyan Glow -->
                        <Border Width="1200" Height="1200" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-300,-300,0,0" Opacity="0.14">
                            <Border.Background>
                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Color="#00d4ff" Offset="0.0"/>
                                    <GradientStop Color="Transparent" Offset="1.0"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Bottom-Right Purple Glow -->
                        <Border Width="1000" Height="1000" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-200,-200" Opacity="0.12">
                            <Border.Background>
                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Color="#8b5cf6" Offset="0.0"/>
                                    <GradientStop Color="Transparent" Offset="1.0"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Center Blue Glow -->
                        <Border Width="800" Height="800" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.06">
                            <Border.Background>
                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Color="#3b82f6" Offset="0.0"/>
                                    <GradientStop Color="Transparent" Offset="1.0"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.Background>

        <!-- Main layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Left Navigation Sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Right Content Area -->
            </Grid.ColumnDefinitions>

            <!-- ============================================================
                 LEFT NAVIGATION SIDEBAR (COLLAPSIBLE)
                 ============================================================ -->
            <Border Grid.Column="0" Style="{StaticResource SidebarBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Top Header / Toggle -->
                        <RowDefinition Height="Auto"/> <!-- Divider -->
                        <RowDefinition Height="*"/>    <!-- Navigation Buttons Stack -->
                        <RowDefinition Height="Auto"/> <!-- Bottom Actions & Profile -->
                    </Grid.RowDefinitions>

                    <!-- Top Header / Toggle -->
                    <Grid Grid.Row="0" Height="46" Margin="0,0,0,6">
                        <!-- Logo & Title (Visible when expanded) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0"
                                    Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}">
                            <Border Width="30" Height="30" CornerRadius="8" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00d4ff" Offset="0.0"/>
                                        <GradientStop Color="#3b82f6" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentControl Content="{StaticResource IconShield}" Style="{StaticResource DfirIcon}" Foreground="White" Width="14" Height="14"/>
                            </Border>
                            <TextBlock Text="Stormbreaker" Foreground="White" FontSize="13.5" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Hamburger Toggle Button -->
                        <Button Command="{Binding ToggleSidebarCommand}" Width="36" Height="36" Padding="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnGlass}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Margin" Value="0,0,16,0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <ContentControl Content="{StaticResource IconMenu}" Style="{StaticResource DfirIcon}" Width="15" Height="15"/>
                        </Button>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Row="1" Height="1" Background="{StaticResource GlassBorderBrush}" Margin="0,4,0,8" x:Name="TopDivider">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Width" Value="24"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                        <Setter Property="Width" Value="198"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Main Navigation Buttons Stack -->
                    <StackPanel Grid.Row="2" HorizontalAlignment="Stretch">
                        <!-- Dashboard -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="dashboard"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=dashboard}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=dashboard}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconLayoutGrid}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=dashboard}"/>
                                <TextBlock Grid.Column="1" Text="Dashboard" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=dashboard}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <!-- Event Logs (with alert badge) -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="events"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=events}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=events}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconFileText}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=events}"/>
                                
                                <!-- Overlapping badge only when collapsed -->
                                <Border Grid.Column="0" Background="{StaticResource AccentRedBrush}" Width="14" Height="14" CornerRadius="7"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0" IsHitTestVisible="False"
                                        Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVis}}">
                                    <TextBlock Text="3" Foreground="White" FontSize="8.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" Text="Event Logs" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=events}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                                
                                <!-- Expanded badge -->
                                <Border Grid.Column="2" Background="#26ef4444" BorderBrush="#51ef4444" BorderThickness="1" Width="18" Height="18" CornerRadius="9" Margin="0,0,12,0" VerticalAlignment="Center"
                                        Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="3" Foreground="{StaticResource AccentRedBrush}" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- MFT Explorer -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="mft"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=mft}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=mft}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconHardDrive}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=mft}"/>
                                <TextBlock Grid.Column="1" Text="MFT Triage" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=mft}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <!-- Timeline -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="timeline"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=timeline}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=timeline}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconClock}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=timeline}"/>
                                <TextBlock Grid.Column="1" Text="Super Timeline" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=timeline}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <!-- Correlation -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="correlation"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=correlation}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=correlation}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconGitMerge}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=correlation}"/>
                                <TextBlock Grid.Column="1" Text="Attack Map" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=correlation}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <!-- AI Analyst -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="ai"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=ai}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=ai}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconBrain}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=ai}"/>
                                <TextBlock Grid.Column="1" Text="AI Analyst" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=ai}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <!-- Reports & IOCs -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="reports"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=reports}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=reports}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconFileSearch}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=reports}"/>
                                <TextBlock Grid.Column="1" Text="Reports &amp; IOCs" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=reports}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <!-- Bottom Profile / Actions -->
                    <StackPanel Grid.Row="3" Margin="0,8,0,0">
                        <!-- Settings -->
                        <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="settings"
                                Background="{Binding CurrentView, Converter={StaticResource ActiveViewToBrush}, ConverterParameter=settings}"
                                BorderBrush="{Binding CurrentView, Converter={StaticResource ActiveViewToBorderBrush}, ConverterParameter=settings}">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Grid.Column="0" Content="{StaticResource IconSettings}" Style="{StaticResource DfirIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=settings}"/>
                                <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" FontSize="12.5" FontWeight="Medium"
                                           Foreground="{Binding CurrentView, Converter={StaticResource ActiveViewToForeground}, ConverterParameter=settings}"
                                           Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <!-- Divider -->
                        <Border Width="24" Height="1" Background="{StaticResource GlassBorderBrush}" Margin="0,10" x:Name="BottomDivider">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Width" Value="24"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                            <Setter Property="Width" Value="198"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- User Profile Card -->
                        <Grid Margin="11,4" Cursor="Hand" ToolTip="Analista — Yoandy R.">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Avatar -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" BorderBrush="#1AFFFFFF" BorderThickness="1.5" HorizontalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#f472b6" Offset="0.0"/>
                                        <GradientStop Color="#8b5cf6" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="YR" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Profile details (expanded only) -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                        Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Yoandy R." Foreground="White" FontSize="12.5" FontWeight="Bold"/>
                                <TextBlock Text="DFIR Analyst" Foreground="{StaticResource TextMutedBrush}" FontSize="9.5" FontWeight="SemiBold" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================================
                 RIGHT COLUMN: PERSISTENT HEADER + CONTENT VIEW AREA
                 ============================================================ -->
            <Grid Grid.Column="1" Margin="14,18,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Persistent Top Header Panel (Glass Border & Backplate) -->
                <Border Grid.Row="0"
                        Background="{StaticResource BgPanelBrush}"
                        BorderBrush="{StaticResource GlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="20,13"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Brand Logo + Name -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="44" Height="44" CornerRadius="14" Margin="0,0,13,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00d4ff" Offset="0.0"/>
                                        <GradientStop Color="#3b82f6" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentControl Content="{StaticResource IconShield}" Style="{StaticResource DfirIcon}" Foreground="White" Width="22" Height="22"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Stormbreaker DFIR" FontSize="21" FontWeight="ExtraBold">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#e8ecf4" Offset="0.0"/>
                                            <GradientStop Color="#00d4ff" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="CASE · " FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Case.Id}" FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold"/>
                                    <TextBlock Text=" · " FontSize="10.5" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding Case.Host}" FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Header Global Controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource BtnGlass}" Command="{Binding ToggleImportModalCommand}" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <ContentControl Content="{StaticResource IconUpload}" Style="{StaticResource DfirIcon}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Import Evidence" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnGlass}" Command="{Binding QuickScanCommand}" Margin="0,0,10,0" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <ContentControl Content="{StaticResource IconZap}" Style="{StaticResource DfirIcon}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Quick Scan" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BtnPrimary}" Command="{Binding RunAiAnalysisCommand}" CommandParameter="">
                                <StackPanel Orientation="Horizontal">
                                    <ContentControl Content="{StaticResource IconBrain}" Style="{StaticResource DfirIcon}" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="Generate AI Report" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ============================================================
                     VIEW CONTROLS CONTAINER (Toggled via CurrentView Binding)
                     ============================================================ -->
                <Grid Grid.Row="1">
                    <!-- Dashboard View -->
                    <views:DashboardView>
                        <views:DashboardView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="dashboard">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:DashboardView.Style>
                    </views:DashboardView>

                    <!-- Events View -->
                    <views:EventsView>
                        <views:EventsView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="events">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:EventsView.Style>
                    </views:EventsView>

                    <!-- Mft View -->
                    <views:MftView>
                        <views:MftView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="mft">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:MftView.Style>
                    </views:MftView>

                    <!-- Timeline View -->
                    <views:TimelineView>
                        <views:TimelineView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="timeline">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:TimelineView.Style>
                    </views:TimelineView>

                    <!-- Correlation View -->
                    <views:CorrelationView>
                        <views:CorrelationView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="correlation">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:CorrelationView.Style>
                    </views:CorrelationView>

                    <!-- AI View -->
                    <views:AiView>
                        <views:AiView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="ai">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:AiView.Style>
                    </views:AiView>

                    <!-- Reports View -->
                    <views:ReportsView>
                        <views:ReportsView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="reports">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:ReportsView.Style>
                    </views:ReportsView>

                    <!-- Settings View -->
                    <views:SettingsView>
                        <views:SettingsView.Style>
                            <Style TargetType="UserControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentView}" Value="settings">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:SettingsView.Style>
                    </views:SettingsView>
                </Grid>
            </Grid>
        </Grid>

        <!-- ============================================================
             OVERLAY INTERACTIVE MODAL: IMPORT EVIDENCE
             ============================================================ -->
        <Grid x:Name="ImportModalOverlay" 
              Grid.ColumnSpan="2" 
              Background="#A6050810" 
              Visibility="{Binding IsImportModalOpen, Converter={StaticResource BoolToVis}}">
            
            <Border Width="520" Height="Auto" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource GlassBorderLightBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Modal Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ContentControl Content="{StaticResource IconUpload}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,10,0" Width="18" Height="18"/>
                            <TextBlock Text="Import Forensic Evidence" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1" Style="{StaticResource BtnGlass}" Width="30" Height="30" Padding="0" 
                                Command="{Binding ToggleImportModalCommand}">
                            <ContentControl Content="{StaticResource IconX}" Style="{StaticResource DfirIcon}" Width="14" Height="14"/>
                        </Button>
                    </Grid>
                    
                    <!-- Modal Content Dropzone -->
                    <StackPanel Grid.Row="1">
                        <!-- Dropzone simulated border -->
                        <Border BorderBrush="{StaticResource GlassBorderLightBrush}" BorderThickness="1.5" CornerRadius="14" Background="#26000000" Padding="34,20" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <ContentControl Content="{StaticResource IconHardDrive}" Style="{StaticResource DfirIcon}" Foreground="{StaticResource AccentCyanBrush}" Width="38" Height="38" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="Drag forensic artifacts here" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="or click to browse — parsing runs locally, nothing is uploaded" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                
                                <!-- File Format Badges -->
                                <WrapPanel HorizontalAlignment="Center" Margin="0,15,0,0">
                                    <Border Background="#263b82f6" BorderBrush="#513b82f6" BorderThickness="1" CornerRadius="10" Padding="10,3" Margin="3">
                                        <TextBlock Text=".evtx" Foreground="{StaticResource AccentBlueBrush}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#268b5cf6" BorderBrush="#518b5cf6" BorderThickness="1" CornerRadius="10" Padding="10,3" Margin="3">
                                        <TextBlock Text="$MFT" Foreground="{StaticResource AccentPurpleBrush}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#2622c55e" BorderBrush="#5122c55e" BorderThickness="1" CornerRadius="10" Padding="10,3" Margin="3">
                                        <TextBlock Text="$LogFile" Foreground="{StaticResource AccentGreenBrush}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#26f59e0b" BorderBrush="#51f59e0b" BorderThickness="1" CornerRadius="10" Padding="10,3" Margin="3">
                                        <TextBlock Text="USN Journal" Foreground="{StaticResource AccentOrangeBrush}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#26ffffff" BorderBrush="#51ffffff" BorderThickness="1" CornerRadius="10" Padding="10,3" Margin="3">
                                        <TextBlock Text="Registry hive" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
